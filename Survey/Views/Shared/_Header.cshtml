@using Survey.Models
@model MainPageModel

<nav class="ps-navbar">
    <a href="/" class="ps-navbar-brand">
        <div class="brand-icon">
            <i class="fa-solid fa-chart-simple"></i>
        </div>
        PublicSurvey
    </a>

    <ul class="ps-nav-links">
        <li>
            <a asp-area="" asp-controller="MainPage" asp-action="Index" class="nav-link">
                <i class="fa-solid fa-house"></i> Home
            </a>
        </li>

        @if (Model?.Role == Roles.Admin)
        {
            <li>
                <a asp-area="admin" asp-controller="dashboard" asp-action="Index" class="nav-link">
                    <i class="fa-solid fa-shield-halved"></i> Admin
                </a>
            </li>
        }

        @if (Model?.IsUserLogged == true)
        {
            @if (Model?.IsUserCompletedMembership == false)
            {
                <li>
                    <a class="nav-link text-danger" asp-controller="MembershipComplete"
                        asp-action="CustomizeAccordingToRole"
                        asp-route-role="@Model.Role"
                        asp-route-userId="@Model.User.Id">
                        <i class="fa-solid fa-circle-exclamation"></i> Complete Profile
                    </a>
                </li>
            }

            @if ((Model?.Role == Roles.Boss || Model?.Role == Roles.Author) && Model?.IsUserCompletedMembership == true && Model?.IsUserConfirmed == false)
            {
                <li>
                    <span class="ps-nav-alert">
                        <i class="fa-solid fa-clock"></i> Awaiting approval
                    </span>
                </li>
            }
        }
    </ul>

    <div class="ps-nav-actions">
        @if (Model?.IsUserLogged == true)
        {
            <a asp-area="" asp-controller="Chat" asp-action="Index" class="btn btn-ghost btn-sm">
                <i class="fa-brands fa-rocketchat"></i>
            </a>
            <a asp-area="" asp-controller="Account" asp-action="LogOut" class="btn btn-ghost btn-sm">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Log out
            </a>
        }
        else
        {
            <a asp-area="" asp-controller="Account" asp-action="Login" class="btn btn-ghost btn-sm">Log in</a>
            <a asp-area="" asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Sign up</a>
        }
    </div>
</nav>
