@model PostDto

<form asp-controller="Interaction" asp-action="CreatePost">
    <div class="create-post-card">
        <div class="mb-3">
            <textarea class="form-control" asp-for="Content" placeholder="What's on your mind? Share an idea, question, or survey..." rows="3"></textarea>
        </div>
        <div class="d-flex align-items-center justify-content-between">
            <select class="form-control" asp-for="IsGlobalString" style="width:auto; min-width:130px;">
                <option value="global" selected><i class="fa-solid fa-globe"></i> Global</option>
                <option value="local">Local</option>
            </select>
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-paper-plane"></i> Publish
            </button>
        </div>
    </div>
</form>
