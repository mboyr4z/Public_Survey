@using Survey.Benimkiler
@model List<ShowedPost>

@inject MainPageModel _mainPageModel
@inject IServiceManager _manager
@inject IHttpContextAccessor HttpContextAccessor

@{
    var returnUrl = $"{HttpContextAccessor.HttpContext.Request.Path}{HttpContextAccessor.HttpContext.Request.QueryString}";
}

@foreach (ShowedPost showedPost in Model)
{
    <div class="post-card">
        <div class="post-card-header">
            <div class="post-author">
                <img src="@showedPost.publisherImagePath" alt="@showedPost.publisherFullName">
                <div>
                    <div>
                        <a class="post-author-name" asp-page="/RouterPage"
                            asp-route-userId="@showedPost.publisherId"
                            asp-route-process=""
                            asp-route-returnUrl="">@showedPost.publisherFullName</a>
                    </div>
                    <div class="post-author-info">@showedPost.publisherInformation</div>
                </div>
            </div>

            @if (_mainPageModel.User is not null && !showedPost.publisherId.Equals(_mainPageModel.User.Id))
            {
                if (_manager.FollowService.GetAllFollows(false)
                    .Where(p => p.FollowById.Equals(_mainPageModel.User.Id) && p.FollowedId.Equals(showedPost.publisherId))
                    .FirstOrDefault() is null)
                {
                    <a asp-page="/Follow"
                        asp-route-followedId="@showedPost.publisherId"
                        asp-route-followerId="@_mainPageModel.User.Id"
                        asp-route-returnUrl="@returnUrl"
                        class="btn-follow">
                        <i class="fa-solid fa-plus"></i> Follow
                    </a>
                }
            }
        </div>

        <div class="post-card-body">
            <div class="post-time">
                <i class="fa-regular fa-clock"></i>
                @showedPost.publishTime
            </div>
            <p class="post-content">@showedPost.content</p>
        </div>

        <div class="post-card-footer">
            @{
                string likeClass = "fa-solid fa-heart";
                string likeOrDislikePage = "/Like";

                if (_mainPageModel.User is not null && _manager.LikeService.IsUserLikeTePost(_mainPageModel.User.Id, showedPost.postId))
                {
                    likeClass += " liked";
                    likeOrDislikePage = "/Unlike";
                }
            }

            @if (_mainPageModel.User is not null)
            {
                <a asp-page="@likeOrDislikePage"
                    asp-route-likerId="@_mainPageModel.User.Id"
                    asp-route-postId="@showedPost.postId"
                    asp-route-returnUrl="@returnUrl"
                    class="post-action @(likeClass.Contains("liked") ? "liked" : "")">
                    <i class="@likeClass"></i>
                    @showedPost.likeCount Like@(showedPost.likeCount != 1 ? "s" : "")
                </a>
            }
            else
            {
                <span class="post-action">
                    <i class="fa-solid fa-heart"></i>
                    @showedPost.likeCount Like@(showedPost.likeCount != 1 ? "s" : "")
                </span>
            }

            <button class="post-action" id="comment_@showedPost.postId" onclick="showCommentInput(this.id)">
                <i class="fa-regular fa-comment"></i>
                @showedPost.commentCount Comment@(showedPost.commentCount != 1 ? "s" : "")
            </button>
        </div>

        <div style="display:none;" id="commentArea_@showedPost.postId">
            @await Component.InvokeAsync("ShowComments", new { postId = showedPost.postId })
        </div>
    </div>
}

<script>
    function showCommentInput(id) {
        var postId = id.split('_')[1];
        var commentArea = document.getElementById('commentArea_' + postId);
        commentArea.style.display = commentArea.style.display === 'none' ? 'block' : 'none';
    }
</script>
