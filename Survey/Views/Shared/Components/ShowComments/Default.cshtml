@model ShowCommentsItem
@inject MainPageModel _mainPageModel
@inject IServiceManager _manager
@inject IHttpContextAccessor HttpContextAccessor

@{
    var returnUrl = $"{HttpContextAccessor.HttpContext.Request.Path}{HttpContextAccessor.HttpContext.Request.QueryString}";
}

<div class="comment-section">
    @if (_mainPageModel.User is not null && await _manager.IsSurveyUserMembershipCompletedAsync(_mainPageModel.User))
    {
        <div class="comment-input-row">
            <img src="@Model.userImageUrl" alt="You">
            <input id="comment-input-@Model.postId" type="text" placeholder="Write a comment...">
            <button onclick="submitComment('@Model.postId')" class="btn btn-primary btn-sm">
                Post
            </button>
        </div>
    }

    @foreach (CommentItem item in Model.commentItems)
    {
        <div class="comment-item">
            <img src="@item.CommenterImageUrl" alt="@item.FullName">
            <div class="comment-bubble">
                <a class="comment-author-name" asp-page="/RouterPage" asp-route-userId="@item.CommentatorId">@item.FullName</a>
                <p class="comment-content">@item.Content</p>
                <div class="comment-meta">
                    <i class="fa-regular fa-clock"></i>
                    @item.PublishTime
                </div>
            </div>
        </div>
    }
</div>

<script>
    function submitComment(postId) {
        var commentContent = document.getElementById('comment-input-' + postId).value;
        var userId = '@_mainPageModel.User?.Id';
        var returnUrl = '@returnUrl';
        window.location.href = `/CreateComment?content=${encodeURIComponent(commentContent)}&commenterId=${userId}&postId=${postId}&returnUrl=${encodeURIComponent(returnUrl)}`;
    }
</script>
